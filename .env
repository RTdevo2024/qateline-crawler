# =============================================
# qateline-crawler — Environment Variables
# =============================================
# این فایل را کپی کنید به .env.local و مقادیر واقعی را پر کنید
# هرگز .env.local را commit نکنید

# --- Database ---
# فرمت: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/qateline_crawler"

# --- Redis (BullMQ Broker) ---
# فرمت: redis://<host>:<port>
REDIS_URL="redis://localhost:6379"

# --- OpenAI ---
OPENAI_API_KEY="sk-..."
# مدل پیش‌فرض: gpt-4o (می‌توان با این متغیر تغییر داد)
# OPENAI_MODEL="gpt-4o"

# --- Ghateline API ---
GHATELINE_API_KEY="your-ghateline-api-key-here"
GHATELINE_API_BASE_URL="https://ghateline.com"

# شناسه کاربر admin در سیستم قطعه‌لاین (برای انتساب محصولات)
GHATELINE_ADMIN_USER_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# UUID انبار پیش‌فرض برای ایجاد موجودی
GHATELINE_DEFAULT_STORAGE_UUID="zzzzzzzz-zzzz-zzzz-zzzz-zzzzzzzzzzzz"

# --- NextAuth.js ---
# یک رشته تصادفی قوی: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
